# Ortus Configuration Example
# Copy this file to config.yaml and adjust as needed

server:
  host: "0.0.0.0"
  port: 8080
  read_timeout: 30s
  write_timeout: 30s
  shutdown_timeout: 10s
  rate_limit:
    enabled: false
    rate: 100.0
    burst: 200
  cors:
    # Allowed origins for CORS requests
    # Supports exact matches and wildcard patterns (e.g., "*.example.com")
    # Leave empty to disable CORS
    allowed_origins: []
    # Examples:
    # allowed_origins:
    #   - "https://example.com"
    #   - "https://app.example.com"
    #   - "*.sub.domain.tld"

storage:
  # Storage type: local, s3, azure, http
  type: local
  local_path: ./data

  # AWS S3 configuration (when type: s3)
  s3:
    bucket: ""
    region: "eu-central-1"
    prefix: ""
    # endpoint: ""  # For S3-compatible storage
    # access_key_id: ""
    # secret_access_key: ""

  # Azure Blob Storage configuration (when type: azure)
  azure:
    container: ""
    account_name: ""
    # account_key: ""
    # connection_string: ""
    prefix: ""

  # HTTP download configuration (when type: http)
  http:
    base_url: ""
    index_file: "index.txt"  # File listing available GeoPackages
    timeout: 5m
    # username: ""
    # password: ""

query:
  timeout: 30s
  max_features: 1000

# Remote storage sync configuration
# Periodically checks remote storage (S3/Azure/HTTP) for new GeoPackages
sync:
  enabled: false      # Enable periodic sync (only for remote storage types)
  interval: "1h"      # Sync interval (e.g., "30m", "1h", "24h")
  # Note: A manual sync API endpoint is available at POST /api/v1/sync
  # Rate limited to 2 requests per minute

tls:
  enabled: false
  domains: []
  email: ""
  cache_dir: "./.certmagic"
  staging: false  # Use Let's Encrypt staging for testing
  dns:
    provider: "azure"
    subscription_id: ""
    resource_group_name: ""
    # For User Assigned Managed Identity (optional)
    # If empty, System Assigned Managed Identity is used
    # client_id: ""

metrics:
  enabled: true
  port: 9090            # Prometheus scrape port (separate from main HTTP)
  path: "/metrics"
  # Optional OTLP push of metrics to a collector, alongside the
  # Prometheus scrape. Endpoint falls back to tracing.endpoint when empty.
  otlp:
    enabled: false
    endpoint: ""        # host:port; empty ⇒ fall back to tracing.endpoint
    transport: "http"   # http | grpc
    insecure: true
    interval: 60s       # PeriodicReader collection interval
    # headers:
    #   Authorization: "Bearer <token>"

logging:
  level: "info"  # debug, info, warn, error
  format: "json"  # json, text

# Model Context Protocol server. Off by default. When enabled, ortus
# exposes a streamable-HTTP MCP endpoint with diagnostic and query tools
# for AI agents. The bearer token is loaded from the ORTUS_MCP_TOKEN
# env var, NOT from this file.
mcp:
  enabled: false
  host: "127.0.0.1"   # 127.0.0.1 = no token required; anything else requires ORTUS_MCP_TOKEN
  port: 9091
  path: "/mcp"

# Raster-bundle adapter (COG *.zip sources).
raster:
  # Per-bundle extracted-size cap (decompression-bomb guard). Default 8 GiB.
  # Raise it for large trusted bundles such as continental DEM tile sets — the
  # West-Palearctic elevation bundle is ~40 GiB.
  max_bundle_extract_gib: 8
  # Persistent, content-addressed extraction cache. "" = unpack to an OS temp dir
  # on every start (slow for the ~48 GB DEM). Set to a durable, mounted volume to
  # unpack once into <dir>/<id>@<fingerprint> and reuse across restarts/updates;
  # re-extraction happens only when the ZIP content changes.
  extract_cache_dir: ""
  # Remove old cached extractions of a source after a new fingerprint loads.
  # Keep false if container starts can overlap (rolling update) — see the docs.
  extract_cache_prune: false

# Gazetteer (reverse geocoding + bearing / "Peilung"). A dedicated places/admin
# GeoPackage, loaded separately from the generic query source pool. Disabled by
# default — the feature is inert until enabled with the paths below.
gazetteer:
  enabled: false
  geopackage_path: ""       # path to the places/admin GeoPackage
  manifest_path: ""         # ortus-gazetteer.yaml (layer/column role mapping)
  level_reference_path: ""  # optional admin-level sidecar (enriches Locate with tier meaning)
  name_source_manifest_path: ""  # optional name-source manifest (describes romanization/provenance codes in the response-wide sources block)
  # Bearing tuning knobs. Reach = the radius within which a class is an acceptable
  # anchor; prefer_nearest_km = a town-or-larger anchor within this radius wins
  # outright (villages excluded). Defaults shown.
  bearing:
    reach_village_km: 5       # used by the "rank" strategy (per-class candidate reach)
    reach_town_km: 18
    reach_city_km: 60
    prefer_nearest_km: 5      # "rank": a town-or-larger within this radius wins outright
    inside_label_km: 1
    compass_points: 8         # 8 or 16
    # Anchor selection strategy: "composite" (default — prominence-vs-proximity, uses the
    # enriched population/capital/wikidata columns; falls back to class where absent) or
    # "rank" (the original class-then-distance behaviour).
    salience: composite
    composite:                # tuning for the composite strategy (calibrated "balanced" defaults)
      candidate_radius_km: 120  # flat gather radius for all classes; decay shapes the outcome
      pop_weight: 1.0           # multiplier on log10(1+population)
      wiki_weight: 0.3          # bonus when a place has a wikidata QID
      decay_per_km: 0.04        # score subtracted per km (prominence↔proximity slope)
      capital_scale: 0.8        # scales the capital-rank bonus (national/regional seat)
      # class_prior/capital_bonus override the calibrated tables (partial: only the
      # listed keys change). class_prior = base score for places with no population;
      # capital_bonus = per-OSM-capital-rank bonus (before capital_scale).
      # class_prior: { city: 4.3, town: 3.3, village: 2.3 }
      # capital_bonus: { "2": 2.0, "3": 1.5, "4": 1.2, "5": 0.6, "6": 0.4, "7": 0.2, "yes": 2.0 }
  # Elevation (Höhe über NN) at the query point, sampled from a continuous raster
  # DEM. The DEM is gazetteer-owned: opened "out of competition" from bundle_path
  # (like geopackage_path above), NOT via the source pool — so it never appears in
  # GET /api/v1/sources and is never point-in-polygon queried. Off unless bundle_path
  # is set; a missing/unopenable bundle is non-fatal (elevation + exposure stay silent).
  elevation:
    bundle_path: ""           # gazetteer-owned DEM bundle .zip (e.g. /data/gazetteer/copernicus-dem.zip); empty = feature off
    layer: elevation          # continuous elevation layer id within that bundle
    accuracy_layer: ""        # optional continuous per-point accuracy layer (e.g. HEM); "" = off
    tile_cache_size: 64       # open-tile LRU bound for multi-tile DEMs
    vertical_datum: EGM2008   # surfaced in the response (Höhe über NN ≈ orthometric)
    accuracy_m: 4.0           # vertical accuracy constant (dataset LE90); used when accuracy_layer is unset
    accuracy_basis: "GLO-30 LE90 (absolute)"
    per_point_accuracy_basis: "Copernicus HEM (per-pixel 1σ)"  # basis reported when accuracy_layer is set
    horizontal_accuracy_m: 6.0
    surface_model: DSM        # GLO-30 is a surface model (incl. vegetation/buildings)

# OpenTelemetry tracing configuration.
# When enabled, spans are kept in an in-memory ring buffer (for the MCP server
# to query directly) and, if endpoint is set, also exported via OTLP.
tracing:
  enabled: false
  service_name: "ortus"
  environment: ""           # e.g., "dev", "staging", "prod"
  endpoint: ""              # OTLP collector endpoint as host:port (no scheme — passed verbatim to otlptracehttp/grpc.WithEndpoint)
  transport: "http"         # http | grpc
  insecure: true            # disable TLS to the collector
  sample_ratio: 1.0         # 0.0..1.0; 1.0 = AlwaysOn, 0.0 = NeverSample
  buffer_size: 256          # number of traces retained in memory for MCP queries
  # headers:                # optional OTLP headers (auth tokens etc.)
  #   Authorization: "Bearer <token>"
  # attributes:             # static resource attributes
  #   cluster: "prod-eu"
