{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "ortus — load test",
  "uid": "ortus-loadtest",
  "schemaVersion": 39,
  "tags": ["ortus", "loadtest"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "title": "Request rate (req/s) by status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(ortus_http_requests_total[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Latency p50 / p95 / p99 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ortus_http_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ortus_http_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ortus_http_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Latency p95 by route (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(ortus_http_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "title": "Sources (loaded / ready / failed)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "ortus_sources_loaded", "legendFormat": "loaded" },
        { "refId": "B", "expr": "ortus_sources_ready", "legendFormat": "ready" },
        { "refId": "C", "expr": "ortus_sources_failed", "legendFormat": "failed" }
      ]
    },
    {
      "title": "Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "expr": "{job=\"ortus\"}" }
      ]
    }
  ]
}
