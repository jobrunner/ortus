{
  "mcpServers": {
    "ortus": {
      "type": "http",
      "url": "http://ortus:9091/mcp",
      "headers": {
        "Authorization": "Bearer ${ORTUS_MCP_TOKEN}"
      }
    },
    "github": {
      "command": "sh",
      "args": [
        "-c",
        "GITHUB_PERSONAL_ACCESS_TOKEN=$(gh auth token) exec github-mcp-server stdio"
      ]
    }
  }
}
